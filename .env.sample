TOKEN="ここにアクセストークンを入れてください。"
HOST="ここはホスト名を入れてください。例: misskey.example.tld"

# --- オプション設定（設定しない場合はデフォルト値が使用されます） ---

# 削除処理の間隔（秒）
# 最小値は5秒。5未満は30秒にクランプされます。
# デフォルト: 30
# DELETE_INTERVAL=30

# --- ノート削除設定 ---

# ノートの保持期間（duration形式: 7d, 12h, 30m, 1h30m など）
# 0 または未設定で期間フィルタ無効
# デフォルト: (無効)
# NOTE_OLDER_THAN=7d

# リアクションがあるノートを保持するか (true / false)
# デフォルト: false
# KEEP_WITH_REACTIONS=false

# リノートされているノートを保持するか (true / false)
# デフォルト: false
# KEEP_WITH_RENOTES=false

# 保持条件の判定モード (or / and)
# or : いずれかの条件を満たせば保持
# and: 有効な条件をすべて満たした場合のみ保持
# デフォルト: or
# KEEP_CONDITION_MODE=or

# --- ドライブファイル削除設定 ---

# ドライブファイルの保持期間（duration形式）
# 0 または未設定で期間フィルタ無効
# デフォルト: (無効)
# DRIVE_OLDER_THAN=30d

# ドライブ削除モード (none / all / unused)
# none  : ドライブファイルを削除しない
# all   : 全ドライブファイルを削除（プロフィール画像を除く）
# unused: ノートに添付されていないファイルのみ削除
# デフォルト: none
# DRIVE_MODE=none

# ノート削除をスキップしドライブのみ処理 (true / false)
# デフォルト: false
# SKIP_NOTES=false

# --- セーフガード ---

# ドライラン（削除対象の表示のみ。実際の削除は行わない）
# デフォルト: false
# DRY_RUN=false

# 確認プロンプトをスキップ (true / false)
# デフォルト: false
# YES=false

# 最大削除数（N件削除で停止。0=無制限）
# デフォルト: 0
# MAX_DELETE=0

# 既存のロックファイルを無視して起動 (true / false)
# デフォルト: false
# FORCE=false

# --- ログ設定 ---

# 詳細ログ（スキップ理由も表示）
# デフォルト: false
# VERBOSE=false

# エラーのみ表示
# デフォルト: false
# QUIET=false
